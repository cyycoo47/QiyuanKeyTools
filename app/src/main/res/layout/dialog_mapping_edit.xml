<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 按键标识 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="按键："
            android:textSize="12sp"
            android:textColor="@color/on_surface_dim" />

        <TextView
            android:id="@+id/tv_key_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:paddingBottom="12dp" />

        <!-- 动作类型 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="执行动作"
            android:textSize="13sp"
            android:textColor="@color/on_surface" />

        <Spinner
            android:id="@+id/spinner_action_type"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="12dp" />

        <!-- ── 广播面板 ── -->
        <LinearLayout
            android:id="@+id/panel_broadcast"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="广播 Action（如 com.example.MY_ACTION）"
                android:textSize="12sp"
                android:textColor="@color/on_surface_dim" />

            <EditText
                android:id="@+id/et_broadcast_action"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="android.intent.action.XXXXX"
                android:inputType="text"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

        </LinearLayout>

        <!-- ── 启动应用面板 ── -->
        <LinearLayout
            android:id="@+id/panel_launch_app"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="选择应用"
                android:textSize="12sp"
                android:textColor="@color/on_surface_dim" />

            <Spinner
                android:id="@+id/spinner_app"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="8dp" />

        </LinearLayout>

        <!-- ── 系统按键面板 ── -->
        <LinearLayout
            android:id="@+id/panel_keyevent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="系统按键"
                android:textSize="12sp"
                android:textColor="@color/on_surface_dim" />

            <Spinner
                android:id="@+id/spinner_keyevent"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="8dp" />

        </LinearLayout>

        <!-- ── Shell面板 ── -->
        <LinearLayout
            android:id="@+id/panel_shell"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Shell 命令（需系统权限）"
                android:textSize="12sp"
                android:textColor="@color/on_surface_dim" />

            <EditText
                android:id="@+id/et_shell"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="am start -n com.xxx/.MainActivity"
                android:inputType="text"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="8dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
