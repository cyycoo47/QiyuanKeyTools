<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ── SDK 状态卡片 ── -->
        <LinearLayout
            style="@style/CardStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SDK 状态"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface"
                android:paddingBottom="8dp" />

            <TextView
                android:id="@+id/tv_sdk_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:text="● SDK 未连接"
                android:textColor="@color/accent_red" />

            <TextView
                android:id="@+id/tv_app_version"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/on_surface_dim"
                android:paddingTop="6dp" />

            <TextView
                android:id="@+id/tv_sdk_version"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/on_surface_dim"
                android:paddingTop="2dp" />

        </LinearLayout>

        <!-- ── 监听服务开关 ── -->
        <LinearLayout
            style="@style/CardStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="后台监听服务"
                    android:textSize="15sp"
                    android:textColor="@color/on_surface" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="开启后持续在后台监听按键并执行映射"
                    android:textSize="12sp"
                    android:textColor="@color/on_surface_dim" />

            </LinearLayout>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_service"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <!-- ── 属性监听开关 ── -->
        <LinearLayout
            style="@style/CardStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="监听属性"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface"
                android:paddingBottom="8dp" />

            <!-- ROTY_BOX -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="ROTY_BOX (0x4131EC00)"
                    android:textSize="14sp"
                    android:textColor="@color/tag_roty" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_roty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <!-- MFS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="MFS (0x4131EE00)"
                    android:textSize="14sp"
                    android:textColor="@color/tag_mfs" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_mfs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <!-- HW_KEY -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="HW_KEY (0x11410A10)"
                    android:textSize="14sp"
                    android:textColor="@color/tag_hw" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_hw"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

        </LinearLayout>

        <!-- ── 导入/导出配置 ── -->
        <LinearLayout
            style="@style/CardStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="映射配置管理"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface"
                android:paddingBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_export_config"
                    style="@style/Btn.Primary"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="导出配置" />

                <Button
                    android:id="@+id/btn_import_config"
                    style="@style/Btn.Outline"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="导入配置" />

            </LinearLayout>

        </LinearLayout>

        <!-- ── 属性ID参考 ── -->
        <LinearLayout
            style="@style/CardStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="属性 ID 参考"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface"
                android:paddingBottom="8dp" />

            <TextView
                android:id="@+id/tv_prop_ref"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:textColor="@color/on_surface_dim" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
