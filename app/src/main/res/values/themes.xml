<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.QiyuanKeyTools" parent="Theme.Material3.Dark">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:textColorPrimary">@color/on_background</item>
        <item name="android:textColorSecondary">@color/on_surface_dim</item>
    </style>

    <!-- 卡片通用样式 -->
    <style name="CardStyle">
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:padding">12dp</item>
    </style>

    <!-- 通用按钮样式 -->
    <style name="Btn.Primary" parent="Widget.Material3.Button">
        <item name="android:minHeight">48dp</item>
        <item name="android:textSize">14sp</item>
        <item name="backgroundTint">@color/primary</item>
    </style>

    <style name="Btn.Outline" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">48dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/primary</item>
        <item name="strokeColor">@color/primary</item>
    </style>
</resources>
